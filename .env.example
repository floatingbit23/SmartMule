# === SmartMule - Configuración ===
# Copia este archivo como .env y ajusta los valores a tu entorno.

# Carpeta que eMule usa para descargas completadas
INCOMING_PATH=C:\Users\tuUsuario\eMule\Incoming

# Carpeta raíz donde SmartMule organizará los archivos
LIBRARY_PATH=C:\Users\tuUsuario\eMule\SmartMule\Library

# Tiempo de debounce en segundos (para ignorar eventos duplicados de Windows)
DEBOUNCE_SECONDS=3.0

# Tiempo máximo de espera para que eMule libere un archivo (segundos)
FILE_LOCK_TIMEOUT=120

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# === APIs y Modelos de Lenguaje ===
# Token Bearer de la API v3 de The Movie DataBase
TMDB_BEARER_TOKEN=tu_bearer_token_aqui

# User-Agent requerido por APIs comunitarias (OpenLibrary, MusicBrainz) - Usa tu email
CONTACT_EMAIL_USER_AGENT=smartmule-dev@example.com

# API Key de VirusTotal (Triaje de software malicioso)
VIRUSTOTAL_API_KEY=tu_virustotal_api_key_aqui

# API Key de LM Studio Local Inference Server
LMSTUDIO_API_KEY=tu_lm-studio_api_token

# API Key de Gemini (si USE_LOCAL_LLM=False)
GEMINI_API_KEY=tu_gemini_api_key

# Activar o desactivar el uso de un LLM local.
USE_LOCAL_LLM=True
